set_option maxHeartbeats 5000000 in
-- Native evaluation checks the 7 * 3^6 rank-successor identities.
set_option linter.style.nativeDecide false in
theorem smallRank3Z_step :
    forall c : Fin 7, forall x : Fin 6 -> ZMod 3,
      smallRank3Z c (smallReturnSix3 c x) = smallRank3Z c x + 1 := by
  native_decide

set_option maxHeartbeats 5000000 in
-- Native evaluation checks that each color rank table is a permutation.
set_option linter.style.nativeDecide false in
theorem smallRank3Z_bijective : forall c : Fin 7, Function.Bijective (smallRank3Z c) := by
  native_decide

theorem smallReturnSix3_single_cycle (c : Fin 7) :
    IsSingleCycleMap (smallReturnSix3 c) := by
  exact single_cycle_of_zmod_rank
    (f := smallReturnSix3 c)
    (rank := smallRank3Z c)
    (smallRank3Z_bijective c)
    (smallRank3Z_step c)

theorem smallReturn3_single_cycle (c : Fin 7) :
    IsSingleCycleMap (smallReturn3 c) := by
  exact single_cycle_of_bijective_semiconj
    (f := smallReturnSix3 c)
    (g := smallReturn3 c)
    (φ := rootOfSix)
    (Equiv.bijective (rootSixEquiv 3))
    (by intro x; unfold smallReturnSix3; rw [rootOfSix_sixOfRoot])
    (smallReturnSix3_single_cycle c)

def SmallLayer3BijectiveTarget : Prop :=
  forall t c, Function.Bijective (smallLayer3 t c)

def SmallDir3LatinTarget : Prop :=
  forall t w, Function.Bijective fun c : Fin 7 => smallDir3 t w c

def SmallCertificateTarget3WithRank : Prop :=
  SmallLayer3BijectiveTarget ∧ SmallDir3LatinTarget ∧
    (forall c : Fin 7, IsSingleCycleMap (smallReturn3 c))

