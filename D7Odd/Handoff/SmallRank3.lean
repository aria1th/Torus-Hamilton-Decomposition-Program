def smallReturnSix3 (c : Fin 7) (x : Fin 6 -> ZMod 3) : Fin 6 -> ZMod 3 :=
  sixOfRoot (smallReturn3 c (rootOfSix x))


def smallLayerSix3 (t : Fin 3) (c : Fin 7) (x : Fin 6 -> ZMod 3) : Fin 6 -> ZMod 3 :=
  sixOfRoot (smallLayer3 t c (rootOfSix x))

def smallDirSix3 (t : Fin 3) (x : Fin 6 -> ZMod 3) (c : Fin 7) : Fin 7 :=
  smallDir3 t (rootOfSix x) c

